{
  "name": "smoothgesturesplus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:rebuild": "vite optimize --force",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "react-devtools": "react-devtools",
    "react-devtools:patch": "patch-package --error-on-fail && npm run dev:rebuild",
    "react-devtools:unpatch": "patch-package --reverse --error-on-fail && npm run dev:rebuild"
  },
  "dependencies": {
    "immer": "^10.0.4",
    "react": "^18.3.0",
    "react-devtools": "^5.1.0",
    "react-dom": "^18.3.0",
    "use-immer": "^0.9.0",
    "webextension-polyfill": "^0.11.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@types/chrome": "^0.0.266",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/webextension-polyfill": "^0.10.7",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "patch-package": "^8.0.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.10"
  }
}
